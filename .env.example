# ============================================================
# Environment Variables Template
# ============================================================
# Copy this file to .env in the project root:
#   cp .env.example .env
#
# Then fill in your own values below.
# This file is used by docker-compose to pass secrets to services.
# ============================================================

# --- DATABASE ---
# This password is used for BOTH the openGauss superuser (GS_PASSWORD)
# and the application user connection.
# IMPORTANT: openGauss requires passwords to have at least 8 characters
# with uppercase, lowercase, numbers, and special characters.
DB_PASSWORD=Changeme@123

# --- AI / LLM ---
GROQ_API_KEY=your_groq_api_key
HF_TOKEN=your_huggingface_token

# --- EMAIL NOTIFICATIONS ---
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# --- SECURITY ---
# Cryptographically secure 32-byte AES-256 key (Base64 encoded)
# Generate one with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
AES_ENCRYPTION_KEY=your_base64_aes_key
