# ==========================================
# Node.js (React Frontend & Express Gateway)
# ==========================================
# Dependencies
**/node_modules/
package-lock.json

# Build outputs (Vite / React)
**/dist/
dist-ssr/
**/build/

# Node environment logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# Python (FastAPI Internal Service)
# ==========================================
# Compiled byte-compiled / optimized files
**/__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
env/
.venv/
.env/

# Pytest and coverage reports
.pytest_cache/
.coverage
htmlcov/

# ==========================================
# Security & Credentials
# ==========================================
# NEVER commit your environment variables (JWT secrets, Database URLs, API keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# Editor & OS Specific
# ==========================================
# VS Code
.vscode/
*.code-workspace

# Mac/Windows system files
.DS_Store
Thumbs.db

# Ignore the generated RAG vector database
chroma_db/
chroma_db/*